# Appmixer connector skills — environment configuration
# Copy to .env and fill in. All values are read from process.env at runtime.
#
# Scope: SKILLS/plugin-level config (standalone / Claude Code plugin use).
# On an OpenClaw box you don't need this file — the gateway exports the shared
# values (APPMIXER_SKILL_*, APPMIXER_SKILL_CONNECTORS_DIR, APPMIXER_SKILL_GITHUB_PAT) from
# ~/.openclaw/.env (see openclaw/.env.example), or a per-customer workspace
# provides them via appmixer.env.

# ── Appmixer instance (required) ───────────────────────────────────────────
APPMIXER_SKILL_BASE_URL=https://api.appmixer.com
APPMIXER_SKILL_USERNAME=your@email.com
APPMIXER_SKILL_PASSWORD=yourpassword

# Path to the appmixer-connectors working repo (checkout root, not /src).
APPMIXER_SKILL_CONNECTORS_DIR=/path/to/appmixer-connectors

# ── GitHub (required for init-connector: fork + PR workflow) ────────────────
APPMIXER_SKILL_GITHUB_PAT=ghp_xxx

# ── Optional / advanced ────────────────────────────────────────────────────
# Pin a specific auth account for the E2E runner (when the service has several
# accounts and the first one lacks the required OAuth scopes).
# APPMIXER_SKILL_ACCOUNT_ID=
# Pre-obtained Appmixer bearer token; skips username/password auth if set.
# APPMIXER_TOKEN=
# Path to an alternate .env file loaded by the e2e-shared scripts.
# APPMIXER_ENV=
# Runner script timeout in ms (default: 600000 = 10 min).
# AGENT_TIMEOUT_MS=600000
# Verbose tool logging.
# DEBUG=false

# Note: APPMIXER_SKILL_ROOT points at the skills/ directory and is set by the
# runtime (OpenClaw box / installer). Override only if needed.
# APPMIXER_SKILL_ROOT=
