# Appmixer connector skills — environment configuration
#
# Copy this file to ~/.config/appmixer-skills/env and fill it in — the skills
# load it from there automatically. (You don't have to create it by hand:
# on first use the skills ask for the values and write the file for you.)
#
# Precedence: variables exported in your shell always win; APPMIXER_ENV can
# point to an alternate file (e.g. per-instance configs); the default path
# above is the fallback.
#
# This file is the authoritative list: every variable the skills read is here.

# ── Required ────────────────────────────────────────────────────────────────

# Appmixer API host (NOT the designer UI host) + credentials.
# Needed by every skill that talks to a live instance:
# upload-e2e-flows, run-e2e-flows, connector-pipeline.
APPMIXER_SKILL_API_URL=https://api.appmixer.com
APPMIXER_SKILL_USERNAME=your@email.com
APPMIXER_SKILL_PASSWORD=yourpassword

# Root of your appmixer-connectors clone (the directory containing src/appmixer).
# Needed by every skill. May be omitted if you always start the agent from
# inside the clone — the skills then find it by walking up from the cwd.
APPMIXER_SKILL_CONNECTORS_DIR=/path/to/appmixer-connectors

# ── Optional ────────────────────────────────────────────────────────────────

# Designer (UI) base URL — only used to print clickable flow links in
# run-e2e-flows output. When unset, no links are printed.
# APPMIXER_SKILL_UI_URL=https://my.appmixer.com

# ── Troubleshooting escape hatches (leave unset unless a skill tells you) ───

# Pin a specific auth account for the E2E runner — for services with several
# connected accounts where the default one lacks the required OAuth scopes.
# APPMIXER_SKILL_ACCOUNT_ID=

# Pre-obtained Appmixer bearer token; skips username/password auth. For
# SSO-only accounts or passwords that /user/auth rejects.
# APPMIXER_TOKEN=

# run-e2e-flows runner timeout in ms (default: 600000 = 10 min).
# AGENT_TIMEOUT_MS=600000
